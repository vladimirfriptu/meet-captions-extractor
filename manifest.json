{
  "manifest_version": 3,
  "name": "Meet Captions Extractor",
  "version": "1.1.0",
  "description": "Records Google Meet live captions and downloads them as a .txt transcript.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Meet Captions Extractor"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["core.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
